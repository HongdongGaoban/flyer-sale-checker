# ============================================================
# .env.example
# ローカル開発用。実際の値を .env にコピーして使用する
# .env は .gitignore に追加すること（コミット禁止）
# ============================================================

# Google AI Studio から取得
GEMINI_API_KEY=your_gemini_api_key_here

# e-Stat API アプリケーション ID（https://api.e-stat.go.jp/）
ESTAT_APP_ID=your_estat_app_id_here

# Firestore を持つ GCP プロジェクト ID
GCP_PROJECT_ID=your_gcp_project_id_here

# サーバーポート（Cloud Run では 8080 固定）
PORT=8080

# 簡易 API キー認証（空にすると認証スキップ）
# Cloud Run デプロイ後は設定を推奨
API_SECRET=
